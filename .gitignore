# Build artifacts
*.o
Makefile*
*.a
*.so
*.so.*
*.dll
*.dylib

# Executables
XFB
XFB.app/
XFB.exe

# Build directories
build/
build-*/
tmp/
tmp_*/

# Qt Creator user files
*.pro.user
*.pro.user.*

# Debian package files (the final .deb is a release artifact, not source)
*.deb
*.ddeb

# Arch Linux package files (in build directory only)
*.pkg.tar.zst
*.pkg.tar.xz
*.pkg.tar.gz
/pkg/
/.SRCINFO
# Note: Don't ignore src/ as it contains source code!

# macOS build artifacts
*.dmg

# Windows installer output and portable dist folders (release artifacts, large)
XFB-*-Setup.exe
dist/
dist-windows-*/

# UI/MOC generated files (these are generated from source)
ui_*.h
moc_*.cpp
moc_predefs.h
qrc_*.cpp

# Qt Creator and IDE files
.qtc_clangd/
.qmake.stash
*.pro.user*
compile_commands.json

# Qt compiled translation files in build directories (but keep src/*.qm for distribution)
build*/*.qm
tmp*/*.qm

# Database files in build/test directories (but keep src/adb.db as template)
build*/*.db
tmp*/*.db
*.sqlite
*.sqlite3
test*.db

# Internal tracking and progress files (not for public repo)
*_STATUS.md
*_SUMMARY.md
WHAT_WAS_*.md
*_CHECKLIST.md
QUICK_START_*.md
AUR_UPDATE_*.md
*_UPDATES.md
*_ANALYSIS.md
*_COMPARISON.md
*_REFERENCE.txt
reports/

# Misc
.DS_Store
*/.directory
.directory
.cache
.kiro/**.7z
err.txt

# Backup and temporary files
*.backup
*.old
*.tmp
*_minimal.txt
*_minimal.cpp

# Root-level test files (tests should be in tests/ directory)
/test_*.cpp
/test-*.cpp

# IDE / editor configuration
.vscode/
.idea/
.kiro/

# Large local archives (backups etc.)
*.7z

# Local working checkouts of the packaging repositories
aur-xfb/
homebrew-xfb/

# Package build output
output/
dmg_temp/
*.dSYM/

# Generated MOC / QML cache artifacts
*.moc
src/resources_qmlcache.qrc
src/*_qml.cpp
src/qmlcache_loader.cpp

# One-off local debug/test scripts
/fix-qt-*.sh
/test-xfb-*.sh
/test_*.sh
/test_makefile
/test_torrents.sql

# Windows filesystem junk (Thumbs.db + NTFS alternate data streams copied to APFS)
Thumbs.db*
*:Zone.Identifier*
*:encryptable

# Local Windows build tooling
vs_BuildTools.exe*

# Generated by update-aur-docker.sh
Dockerfile.aur-update
*.key
*.pem
.env
*.log
