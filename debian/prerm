#!/bin/bash
# XFB - Pre-removal script

set -e

case "$1" in
    remove|upgrade|deconfigure)
        echo "Preparing to remove XFB..."
        
        # Stop any running XFB processes gracefully (match exact binary name)
        if command -v pkill >/dev/null 2>&1; then
            pkill -x "XFB" 2>/dev/null || true
            # Give processes time to shut down gracefully
            sleep 1
        fi
        
        # Remove any temporary files
        rm -rf /tmp/xfb-* 2>/dev/null || true
        
        # Stop any Tor processes started by XFB
        if [ -d "/tmp/xfb_tor_data" ]; then
            rm -rf /tmp/xfb_tor_data 2>/dev/null || true
        fi
        
        echo "XFB processes stopped."
        ;;
        
    failed-upgrade)
        ;;
        
    *)
        echo "prerm called with unknown argument \`$1'" >&2
        exit 1
        ;;
esac

#DEBHELPER#

exit 0
